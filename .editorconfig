# EditorConfig - エディタのエンコーディングを統一
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = crlf
indent_style = tab
insert_final_newline = true
trim_trailing_whitespace = false

[*.md]
indent_style = space
indent_size = 2

[*.{sln,vcxproj,vcxproj.filters}]
charset = utf-8
end_of_line = crlf
